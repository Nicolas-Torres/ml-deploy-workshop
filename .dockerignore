Thumbs.db

# Secretos y variables de entorno — NUNCA deben viajar al build context
.env
.env.*
*.pem
*.key

# Manifiestos de Kubernetes (los usa cd.yml vía kubectl, no docker build)
k8s/

# Tests (corren en CI fuera del container, no dentro de la imagen)
tests/